# Backend REST API
BACKEND_URL=https://api.softsecure.cl/api

# Socket server
SOCKET_URL=wss://ws.softsecure.cl

# Credenciales del agente (configuradas desde el panel admin)
AGENT_NAME=srv-prod-01
AGENT_KEY=cambia-esto-por-la-clave-del-panel
TENANT_ID=

# Colectores habilitados (true/false)
COLLECT_AUTH=true
COLLECT_PROCESSES=true
COLLECT_NETWORK=true
COLLECT_INTEGRITY=true

# Directorios a monitorear para integridad de archivos (separados por coma)
INTEGRITY_PATHS=/etc,/bin,/usr/bin

# Intervalo de recolección en segundos
COLLECT_INTERVAL=60
